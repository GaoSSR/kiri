{
  "name": "@gaossr/kiri",
  "version": "0.1.18",
  "description": "Kiri CLI for inspecting local development ports; installs the ports command",
  "license": "Apache-2.0",
  "bin": {
    "ports": "./bin/ports.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GaoSSR/kiri.git",
    "directory": "packaging/npm"
  },
  "files": [
    "LICENSE",
    "bin/",
    "lib/",
    "README.md"
  ],
  "optionalDependencies": {
    "@gaossr/kiri-darwin-arm64": "npm:@gaossr/kiri@0.1.18-darwin-arm64",
    "@gaossr/kiri-darwin-x64": "npm:@gaossr/kiri@0.1.18-darwin-x64",
    "@gaossr/kiri-linux-x64": "npm:@gaossr/kiri@0.1.18-linux-x64",
    "@gaossr/kiri-win32-x64": "npm:@gaossr/kiri@0.1.18-win32-x64"
  },
  "scripts": {
    "check": "node --check bin/ports.js && node --check lib/resolve-binary.js && node --check scripts/build-packages.js",
    "pack:dry-run": "npm pack --dry-run",
    "pack:release": "node scripts/build-packages.js --version \"$npm_package_version\" --release-dir ../../dist --output-dir ../../dist/npm",
    "test": "node --test test/*.test.js"
  },
  "engines": {
    "node": ">=18"
  }
}
